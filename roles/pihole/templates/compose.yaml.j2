# Ansible managed
services:
  pihole:
    container_name: pihole
    image: {{ pihole_image }}:{{ pihole_version_tag }}
    # Host networking: FTL binds host interfaces directly (no DNAT / published
    # ports), so DNS is INPUT traffic governed by the host firewall.
    network_mode: host
    environment:
      TZ: "{{ timezone | default('UTC') }}"
      # Admin/API password (interpolated from the .env file next to this compose)
      FTLCONF_webserver_api_password: "${PIHOLE_WEBPASSWORD}"
      # Upstream resolvers
      FTLCONF_dns_upstreams: "{{ dns1 }};{{ dns2 }}"
{% if (pihole_dns_interface | default('')) | length > 0 %}
      # Listen only on this interface (bind-dynamic = no wildcard), so Pi-hole can
      # share :53 with another resolver bound to a different interface.
      FTLCONF_dns_listeningMode: "NONE"
      FTLCONF_misc_dnsmasq_lines: |-
        bind-dynamic
        interface={{ pihole_dns_interface }}
{% else %}
      # No interface set: listen on all interfaces.
      FTLCONF_dns_listeningMode: "all"
{% endif %}
      # Services we don't run: embedded NTP server + time sync, and DHCP server
      FTLCONF_ntp_ipv4_active: "false"
      FTLCONF_ntp_ipv6_active: "false"
      FTLCONF_ntp_sync_active: "false"
      FTLCONF_dhcp_active: "false"
    volumes:
      - "{{ pihole_dir }}/etc-pihole:/etc/pihole"
    cap_add:
      # Allows FTL to set its process priority (matches the previous nice = -10)
      - SYS_NICE
    restart: unless-stopped
