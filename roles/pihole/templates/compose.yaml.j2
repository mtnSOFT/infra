# Ansible managed
services:
  pihole:
    container_name: pihole
    image: {{ pihole_image }}:{{ pihole_version_tag }}
    environment:
      TZ: "{{ timezone | default('UTC') }}"
      # Admin/API password (interpolated from the .env file next to this compose)
      FTLCONF_webserver_api_password: "${PIHOLE_WEBPASSWORD}"
      # Upstream resolvers
      FTLCONF_dns_upstreams: "{{ dns1 }};{{ dns2 }}"
      # Bridge networking: queries reach FTL via the Docker gateway, so accept on
      # all interfaces. Exposure is controlled by the published ports below.
      FTLCONF_dns_listeningMode: "all"
      # Services we don't run: embedded NTP server + time sync, and DHCP server
      FTLCONF_ntp_ipv4_active: "false"
      FTLCONF_ntp_ipv6_active: "false"
      FTLCONF_ntp_sync_active: "false"
      FTLCONF_dhcp_active: "false"
    ports:
      # DNS (53/tcp+udp)
      - "{{ pihole_dns_listen_ip }}:53:53/tcp"
      - "{{ pihole_dns_listen_ip }}:53:53/udp"
      # Web admin (HTTP + HTTPS)
      - "{{ pihole_web_listen_ip }}:80:80/tcp"
      - "{{ pihole_web_listen_ip }}:443:443/tcp"
    volumes:
      - "{{ pihole_dir }}/etc-pihole:/etc/pihole"
    cap_add:
      # Allows FTL to set its process priority (matches the previous nice = -10)
      - SYS_NICE
    restart: unless-stopped
